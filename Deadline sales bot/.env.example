# ============================================================
# DEADLINE BOT — environment variables
# Скопируй этот файл в .env и заполни значения
# .env в git НЕ коммитится (см. .gitignore)
# Provider: Ollama Cloud (OpenAI-compatible endpoint)
# ============================================================

# --- Ollama Cloud (LLM provider) ---
# Получи ключ: https://ollama.com/settings/keys
OLLAMA_API_KEY=REPLACE_ME
OLLAMA_BASE_URL=https://ollama.com/v1

# Модель по умолчанию. Все cloud-модели поддерживают reasoning.
# Список: curl https://ollama.com/api/tags -H "Authorization: Bearer $OLLAMA_API_KEY"
#   qwen3.5:397b-cloud     — самая мощная
#   glm-4.6:cloud          — баланс
#   gpt-oss:120b-cloud     — open OpenAI
#   gemma3:27b             — non-reasoning, fast
LLM_MODEL=qwen3.5:397b-cloud

# Запасная модель — на случай если основная упадёт / залагает
LLM_FALLBACK_MODEL=glm-4.6:cloud

# --- Telegram (handoff notifications) ---
# 1. Открой @BotFather в Telegram, /newbot, получи токен
# 2. Создай группу или используй личку, добавь туда бота
# 3. Получи chat_id: https://api.telegram.org/bot<TOKEN>/getUpdates → "chat":{"id":...}
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# --- Email (опционально, для копии brief'а) ---
# Пока пусто — Telegram достаточно для старта
EMAIL_NOTIFY=corpdeadline@gmail.com

# --- CORS ---
# Через запятую — все домены, с которых можно вызывать /chat
# deadlinecorp.com — основной домен; github.io оставлен как fallback на время переезда DNS
ALLOWED_ORIGINS=https://deadlinecorp.com,https://www.deadlinecorp.com,https://deadline-corp.github.io,http://localhost:3000,http://localhost:5500,http://127.0.0.1:5500

# --- Дебаг ---
LOG_LEVEL=INFO

# --- PostgreSQL (Week 1: добавлен для миграции с Chroma) ---
# Локально: postgresql://postgres:postgres@localhost:5432/deadline_bot
# Railway: подставит автоматически через add-on Postgres
# Supabase: возьмёшь в Project Settings → Database → Connection String → URI
# ВАЖНО: используй sync строку (postgresql://...), не async (postgresql+asyncpg://...)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/deadline_bot

# ============================================================
# CRM Integration (Phase 0c+ added 2026-05-26)
# Feature flag — пока CRM-фичи не доделаны, держим CRM_ENABLED=false.
# При false бот работает 1-в-1 как до интеграции (никаких CRM-вызовов).
# Переключим на true в Railway env когда DOGFOOD GATE.
# ============================================================
CRM_ENABLED=false

# Какую CRM использовать: hubspot | bitrix24 | noop
CRM_PROVIDER=hubspot

# --- HubSpot ---
# Service Key (Beta), формат pat-na2-xxxxxxxx-...
# 1. Settings → Integrations → Service Keys → Create
# 2. Scopes: crm.objects.contacts r+w, crm.objects.companies.read (write пока в Beta недоступен),
#            crm.objects.deals r+w, crm.schemas.contacts r+w, crm.schemas.deals r+w,
#            conversations r+w
# 3. Скопировать токен СРАЗУ (показывается один раз)
HUBSPOT_ACCESS_TOKEN=REPLACE_ME

# Portal ID = HubSpot Account ID, виден в URL app.hubspot.com/.../<portal_id>/...
HUBSPOT_PORTAL_ID=REPLACE_ME

# Регион data center (na1/na2/eu1/...) — из URL app-{region}.hubspot.com
HUBSPOT_REGION=na2

# --- Bitrix24 (опционально, для RU/CIS tenants) ---
# Inbound Webhook URL из bitrix24.ru Developer Resources → Inbound webhook
# Scopes: crm (full), tasks, im (optional), user
# BITRIX24_WEBHOOK_URL=https://<portal>.bitrix24.ru/rest/<user_id>/<webhook_code>/
# BITRIX24_DEFAULT_CATEGORY_ID=1
