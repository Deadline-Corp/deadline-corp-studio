# ============================================================
# DEADLINE BOT — environment variables
# Скопируй этот файл в .env и заполни значения
# .env в git НЕ коммитится (см. .gitignore)
# Provider: Ollama Cloud (OpenAI-compatible endpoint)
# ============================================================

# --- Ollama Cloud (LLM provider) ---
# Получи ключ: https://ollama.com/settings/keys
OLLAMA_API_KEY=REPLACE_ME
OLLAMA_BASE_URL=https://ollama.com/v1

# Модель по умолчанию. Все cloud-модели поддерживают reasoning.
# Список: curl https://ollama.com/api/tags -H "Authorization: Bearer $OLLAMA_API_KEY"
#   qwen3.5:397b-cloud     — самая мощная
#   glm-4.6:cloud          — баланс
#   gpt-oss:120b-cloud     — open OpenAI
#   gemma3:27b             — non-reasoning, fast
LLM_MODEL=qwen3.5:397b-cloud

# Запасная модель — на случай если основная упадёт / залагает
LLM_FALLBACK_MODEL=glm-4.6:cloud

# --- Telegram (handoff notifications) ---
# 1. Открой @BotFather в Telegram, /newbot, получи токен
# 2. Создай группу или используй личку, добавь туда бота
# 3. Получи chat_id: https://api.telegram.org/bot<TOKEN>/getUpdates → "chat":{"id":...}
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# --- Email (опционально, для копии brief'а) ---
# Пока пусто — Telegram достаточно для старта
EMAIL_NOTIFY=corpdeadline@gmail.com

# --- CORS ---
# Через запятую — все домены, с которых можно вызывать /chat
# deadlinecorp.com — основной домен; github.io оставлен как fallback на время переезда DNS
ALLOWED_ORIGINS=https://deadlinecorp.com,https://www.deadlinecorp.com,https://deadline-corp.github.io,http://localhost:3000,http://localhost:5500,http://127.0.0.1:5500

# --- Дебаг ---
LOG_LEVEL=INFO
