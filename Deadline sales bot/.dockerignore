# Secrets — must NEVER be baked into the image
.env
.env.*
!.env.example
*.pem
*.key

# Virtualenv (dependencies are reinstalled via pip inside the image)
venv/
.venv/
env/

# Vector store (large; rebuilt by ingest where needed)
chroma_db/

# Python caches and tests (not needed at runtime)
__pycache__/
*.py[cod]
.pytest_cache/
tests/

# VCS / editor / local
.git/
.gitignore
.vscode/
.idea/
*.log
