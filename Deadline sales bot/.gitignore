# Build / dist
build/
dist/
node_modules/

# admin-ui манифесты: корневой .gitignore студии прячет ЛЮБОЙ package.json/lock,
# из-за чего railway up не заливал их в build-контекст → Docker COPY падал
# («/admin-ui/package.json: not found»). Явно возвращаем их в индексацию.
!admin-ui/package.json
!admin-ui/package-lock.json
*.egg-info/
*.egg

# Chroma DB (regenerated from kb/)
chroma_db/

# Sentence-transformers cache
.cache/
~/.cache/huggingface/

# IDE
.vscode/
.idea/
*.swp
*.swo
.DS_Store

# Logs
